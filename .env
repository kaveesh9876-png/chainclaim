# =============================
# SERVER CONFIG
# =============================
PORT=5000
NODE_ENV=development

# =============================
# DATABASE
# =============================
MONGO_URI=mongodb://localhost:27017/chainclaimnetstat -ano | findstr :5000

# =============================
# JWT AUTH
# =============================
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# =============================
# BLOCKCHAIN - POLYGON zkEVM
# =============================
PRIVATE_KEY=your_wallet_private_key_here
POLYGON_ZKEVM_RPC=https://rpc.public.zkevm-test.net
POLYGON_MAINNET_RPC=https://zkevm-rpc.com

# =============================
# CHAINLINK ORACLE
# =============================
CHAINLINK_NODE_URL=https://your-chainlink-node.com
CHAINLINK_JOB_ID=your_job_id_here

# =============================
# IPFS
# =============================
IPFS_HOST=ipfs.infura.io
IPFS_PORT=5001
IPFS_PROTOCOL=https
INFURA_IPFS_PROJECT_ID=your_infura_project_id
INFURA_IPFS_SECRET=your_infura_secret

# =============================
# IOT GATEWAY
# =============================
IOT_GATEWAY_URL=http://localhost:8080
IOT_API_KEY=your_iot_api_key_here

# =============================
# SMART CONTRACT ADDRESSES
# =============================
CLAIM_PROCESSOR_ADDRESS=0x0000000000000000000000000000000000000000

# =============================
# POLYGONSCAN (for verification)
# =============================
POLYGONSCAN_API_KEY=your_polygonscan_api_key
