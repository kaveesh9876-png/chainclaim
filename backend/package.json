{
    "name": "chainclaim",
    "version": "1.0.0",
    "description": "ChainClaim - Blockchain Insurance Claims Platform on Polygon zkEVM",
    "main": "index.js",
    "scripts": {
        "start": "node backend/server.js",
        "dev": "nodemon backend/server.js",
        "compile": "npx hardhat compile",
        "deploy:testnet": "npx hardhat run scripts/deploy.js --network zkevmTestnet",
        "deploy:mainnet": "npx hardhat run scripts/deploy.js --network zkevmMainnet",
        "deploy:local": "npx hardhat run scripts/deploy.js --network hardhat",
        "test": "npx hardhat test",
        "test:backend": "jest backend/",
        "node:local": "npx hardhat node",
        "verify": "npx hardhat verify --network zkevmTestnet",
        "iot": "python3 iot/sensor_collector.py",
        "lint": "eslint . --ext .js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ethers": "^6.8.0",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "ipfs-http-client": "^60.0.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "socket.io": "^4.6.1",
        "web3": "^4.2.2"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-toolbox": "^4.0.0",
        "hardhat": "^2.19.1",
        "hardhat-gas-reporter": "^1.0.10",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "eslint": "^8.55.0"
    },
    "keywords": [
        "blockchain",
        "insurance",
        "polygon",
        "zkevm",
        "chainlink",
        "iot",
        "ipfs"
    ],
    "author": "Arjun Kumar",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    }
}